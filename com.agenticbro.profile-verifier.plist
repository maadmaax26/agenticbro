<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.agenticbro.profile-verifier</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/efinney/.openclaw/workspace/scripts/start-profile-verifier.sh</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/efinney/.openclaw/workspace/logs/profile-verifier-stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/efinney/.openclaw/workspace/logs/profile-verifier-stderr.log</string>

    <key>WorkingDirectory</key>
    <string>/Users/efinney/.openclaw/workspace</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>

    <key>StartInterval</key>
    <integer>300</integer>

</dict>
</plist>