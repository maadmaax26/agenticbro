# Agentic Bro Payment Wallets

# Solana wallet for receiving USDC and AGNTCBRO payments
# This wallet will receive:
#   - USDC payments on Solana
#   - AGNTCBRO token payments
VITE_PAYMENT_WALLET_SOLANA=YOUR_SOLANA_WALLET_ADDRESS_HERE

# Base wallet for receiving USDC payments
# This wallet will receive:
#   - USDC payments on Base network
VITE_PAYMENT_WALLET_BASE=YOUR_BASE_WALLET_ADDRESS_HERE

# Stripe keys (already configured)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: Supabase for user authentication
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key