# ============================================================
# Agentic Bro — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit real secrets to git.

# ── Supabase (required) ────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
SUPABASE_SECRET_API_KEY=sb_secret_your_key_here

# ── Stripe (required for Brand Guard payments) ─────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# Stripe Subscription Price IDs (create in Stripe Dashboard)
STRIPE_GUARDIAN_PRICE_ID=price_guardian_123
STRIPE_SENTINEL_PRICE_ID=price_sentinel_456
STRIPE_FORTRESS_PRICE_ID=price_fortress_789

# ── Solana ─────────────────────────────────────────────────────
VITE_HELIUS_API_KEY=your-helius-key

# ── AI Provider ────────────────────────────────────────────────
VITE_AI_PROVIDER=ollama
VITE_OLLAMA_API_URL=https://api.ollama.com
VITE_OLLAMA_MODEL=glm-5:cloud

# ── Telegram Bot (required for community bot) ──────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ── Phone Verification ────────────────────────────────────────
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# ── Brand Guard Local Social Scanners ─────────────────────────
BRAND_GUARD_SCANNER_DIR=/Users/efinney/.openclaw/workspace/scripts
BRAND_GUARD_LOCAL_VARIANTS=5
BRAND_GUARD_LOCAL_CONCURRENCY=2
BRAND_GUARD_SCANNER_TIMEOUT_MS=45000
