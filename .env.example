# ============================================================
# Agentic Bro — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit real secrets to git.

# ── Supabase (required) ────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
SUPABASE_SECRET_API_KEY=sb_secret_your_key_here

# ── Stripe (required for Brand Guard payments) ─────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# Stripe Subscription Price IDs (create in Stripe Dashboard)
STRIPE_GUARDIAN_PRICE_ID=price_guardian_123
STRIPE_SENTINEL_PRICE_ID=price_sentinel_456
STRIPE_FORTRESS_PRICE_ID=price_fortress_789

# ── Solana ─────────────────────────────────────────────────────
VITE_HELIUS_API_KEY=your-helius-key

# ── AI Provider ────────────────────────────────────────────────
VITE_AI_PROVIDER=ollama
VITE_OLLAMA_API_URL=https://api.ollama.com
VITE_OLLAMA_MODEL=glm-5:cloud

# ── Telegram Bot (required for community bot) ──────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ── Phone Verification ────────────────────────────────────────
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# ── Brand Guard Local Social Scanners ─────────────────────────
BRAND_GUARD_SCANNER_DIR=/Users/efinney/.openclaw/workspace/scripts
BRAND_GUARD_LOCAL_VARIANTS=5
BRAND_GUARD_LOCAL_CONCURRENCY=2
BRAND_GUARD_SCANNER_TIMEOUT_MS=45000
BRAND_GUARD_API_BASE=https://agenticbro.app
BRAND_GUARD_QUEUE_POLL_MS=10000
BRAND_GUARD_QUEUE_BATCH=2

# Hashes developer request IPs before usage logging.
API_USAGE_HASH_SALT=replace-with-a-long-random-value

# Automated takedown submission gateway. The gateway must implement
# POST /v1/submissions and GET /v1/submissions/:id.
TAKEDOWN_GATEWAY_URL=https://your-takedown-provider.example
TAKEDOWN_GATEWAY_TOKEN=your-provider-token
TAKEDOWN_WORKER_POLL_MS=15000
TAKEDOWN_WORKER_BATCH=5

# Required by Vercel cron endpoints.
CRON_SECRET=replace-with-a-long-random-value

# Customer Slack/webhook delivery. Never rotate this key without migrating
# existing encrypted endpoint records.
DELIVERY_ENCRYPTION_KEY=replace-with-at-least-32-random-characters
DELIVERY_WORKER_POLL_MS=5000
DELIVERY_WORKER_BATCH=10
