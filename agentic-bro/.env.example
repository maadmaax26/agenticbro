# Agentic Bro API Configuration
# Copy this file to .env and fill in your values

# Server Configuration
NODE_ENV=development
HOST=0.0.0.0
PORT=3002

# Database Configuration
DATABASE_URL=postgresql://agenticbro:agenticbro_secret@localhost:5432/agenticbro
DB_USER=agenticbro
DB_PASSWORD=agenticbro_secret
DB_NAME=agenticbro
DB_PORT=5432

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Twitter/X API
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# Botometer API (for bot detection)
BOTOMETER_API_KEY=your_botometer_api_key

# GoPlus Security API (for token scanning)
GOPUS_API_KEY=your_goplus_api_key

# DexScreener API (for token data)
DEXSCREENER_API_KEY=your_dexscreener_api_key

# RugCheck API (for rug detection)
RUGCHECK_API_KEY=your_rugcheck_api_key

# Solana RPC URL (for on-chain data)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Deepfake Detection Model Path
DEEPFAKE_MODEL_PATH=/app/models/deepfake.onnx

# CORS Configuration (comma-separated origins)
CORS_ORIGIN=http://localhost:3000,http://localhost:8080

# Rate Limiting
RATE_LIMIT_FREE=5
RATE_LIMIT_BASIC=50
RATE_LIMIT_PRO=200
RATE_LIMIT_TEAM=1000

# JWT Secret (for session tokens)
JWT_SECRET=your_super_secret_jwt_key_here

# API Key Encryption
API_KEY_SALT=your_api_key_salt_here

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Monitoring
SENTRY_DSN=your_sentry_dsn
PROMETHEUS_PORT=9090