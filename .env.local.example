# Supabase (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Helius (Solana indexer) - optional but recommended
VITE_HELIUS_API_KEY=your-helius-key

# AI Provider Configuration
# Set to 'ollama' to use Ollama cloud (default, free with Ollama Pro)
# Set to 'openai' to use OpenAI (requires API key)
VITE_AI_PROVIDER=ollama

# Ollama Configuration (only if VITE_AI_PROVIDER=ollama)
# Use your existing Ollama Pro endpoint or local Ollama
VITE_OLLAMA_API_URL=https://api.ollama.com
# Choose model: glm-4.7:cloud, qwen3.5:cloud, deepseek-v3.2:cloud, etc.
VITE_OLLAMA_MODEL=glm-4.7:cloud

# OpenAI Configuration (only if VITE_AI_PROVIDER=openai)
VITE_OPENAI_API_KEY=sk-your-openai-key