# ─── AgenticBro Whale Tier — Environment Variables ───────────────────────────
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — NEVER commit real keys to the repo.

# ─── Local Ollama (Mac Studio) ────────────────────────────────────────────────
# IP address or hostname of your Mac Studio running Ollama.
# Example: http://192.168.1.100:11434
OLLAMA_HOST=http://localhost:11434

# Model to use for Whale Chat (must be pulled in Ollama)
OLLAMA_MODEL=qwen3.5:27b

# ─── Ollama Pro (Cloud routing for news/search) ───────────────────────────────
# Your Ollama Pro API endpoint (cloud instance with web search access)
OLLAMA_PRO_HOST=https://ollama.ai

# Cloud model for search queries
OLLAMA_PRO_MODEL=glm-4.7:cloud

# Ollama Pro API key (if required)
# OLLAMA_PRO_API_KEY=your_key_here

# ─── Helius (Solana on-chain data) ────────────────────────────────────────────
# Get your free API key at https://helius.dev
HELIUS_API_KEY=your_helius_api_key_here

# ─── Optional: Custom server port ─────────────────────────────────────────────
# Default is 3001. Change if port is occupied.
# SERVER_PORT=3001

# ─── Existing Vite env vars (already in .env.local) ──────────────────────────
# These should already be present from your existing setup:
# VITE_HELIUS_API_KEY=...  (used client-side for token gating RPC)
# VITE_SUPABASE_URL=...
# VITE_SUPABASE_ANON_KEY=...
