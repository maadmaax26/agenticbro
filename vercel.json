{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/profile-verify.ts": {
      "maxDuration": 30
    },
    "api/scam-investigate.ts": {
      "maxDuration": 30,
      "includeFiles": "api/scammer-database.json"
    },
    "api/scammers.ts": {
      "maxDuration": 10
    },
    "api/scan-report.ts": {
      "maxDuration": 10
    },
    "api/telegram/priority-scan.ts": {
      "maxDuration": 30
    },
    "api/scan.ts": {
      "maxDuration": 15,
      "includeFiles": "lib/scan-tracking.ts"
    },
    "api/social-scan.ts": {
      "maxDuration": 15,
      "includeFiles": "lib/scan-tracking.ts"
    },
    "api/phone-verify.ts": {
      "maxDuration": 15,
      "includeFiles": "lib/scan-tracking.ts"
    },
    "api/phone-scan.ts": {
      "maxDuration": 15
    },
    "api/x-scan.ts": {
      "maxDuration": 15,
      "includeFiles": "lib/scan-tracking.ts"
    },
    "api/website-deep-scan.ts": {
      "maxDuration": 15,
      "includeFiles": "lib/scan-tracking.ts"
    },
    "api/token-impersonation-scan.ts": {
      "maxDuration": 15,
      "includeFiles": "lib/scan-tracking.ts"
    },
    "api/scan/[job_id].ts": {
      "maxDuration": 10
    },
    "api/brand-guard/brands.ts": {
      "maxDuration": 15
    },
    "api/brand-guard/credits.ts": {
      "maxDuration": 15
    },
    "api/brand-guard/impersonator-scan.ts": {
      "maxDuration": 30
    },
    "api/brand-guard/stripe-webhook.ts": {
      "maxDuration": 15
    },
    "api/brand-guard/dashboard.ts": {
      "maxDuration": 15
    },
    "api/brand-guard/domain-monitor.ts": {
      "maxDuration": 15
    },
    "api/brand-guard/threat-correlate.ts": {
      "maxDuration": 15
    },
    "api/brand-guard/vendor-verify.ts": {
      "maxDuration": 15
    }
  },
  "rewrites": [
    { "source": "/api/scan/:job_id", "destination": "/api/scan/[job_id].ts" },
    { "source": "/api/scan", "destination": "/api/scan.ts" },
    { "source": "/api/phone-scan/:job_id", "destination": "/api/phone-scan/[job_id].ts" },
    { "source": "/api/phone-scan", "destination": "/api/phone-scan.ts" },
    { "source": "/api/brand-guard/stripe-webhook", "destination": "/api/brand-guard/stripe-webhook.ts" },
    { "source": "/api/brand-guard/credits/:path*", "destination": "/api/brand-guard/credits.ts" },
    { "source": "/api/brand-guard/brands/:path*", "destination": "/api/brand-guard/brands.ts" },
    { "source": "/api/brand-guard/dashboard/:path*", "destination": "/api/brand-guard/dashboard.ts" },
    { "source": "/api/brand-guard/impersonator-scan/:path*", "destination": "/api/brand-guard/impersonator-scan.ts" },
    { "source": "/api/brand-guard/:path*", "destination": "/api/brand-guard/:path*" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}